# Copie este arquivo para .env e ajuste os valores do seu ambiente.

# Projeto Google Cloud para consultas BigQuery (obrigatório)
# Precisa de billing ativo — BasedosDados consome cota BigQuery
BASEDOSDADOS_BILLING_PROJECT_ID=seu-projeto-gcp

# Pasta dos CSVs baixados do BigQuery
DOACOES_CAMPANHA_RAW_DIR=output/dados-doacoes-campanha

# Banco PostgreSQL
DB=postgres
DB_USER=postgres
DB_PASSWORD=sua-senha
DB_HOST=localhost
DB_PORT=5432

# Database e schema para as tabelas TSE
TSE_DB=postgres
TSE_SCHEMA=tse
